CREATE TABLE ModelEntity (
    id TEXT PRIMARY KEY NOT NULL,
    name TEXT NOT NULL,
    provider TEXT NOT NULL,
    description TEXT
);

CREATE TABLE ChatSessionEntity (
    id TEXT PRIMARY KEY NOT NULL,
    title TEXT NOT NULL,
    createdAt INTEGER NOT NULL,
    modelId TEXT NOT NULL,
    providerId TEXT NOT NULL DEFAULT 'ollama',
    FOREIGN KEY (modelId) REFERENCES ModelEntity(id)
);

CREATE TABLE MessageEntity (
    id TEXT PRIMARY KEY NOT NULL,
    sessionId TEXT NOT NULL,
    role TEXT NOT NULL,
    content TEXT NOT NULL,
    timestamp INTEGER NOT NULL,
    attachments TEXT,
    FOREIGN KEY (sessionId) REFERENCES ChatSessionEntity(id)
);

CREATE TABLE AppStateEntity (
    id TEXT PRIMARY KEY NOT NULL,
    value TEXT NOT NULL
);

CREATE TABLE AuditEventEntity (
    id TEXT PRIMARY KEY NOT NULL,
    kind TEXT NOT NULL,
    sessionId TEXT,
    approvalId TEXT,
    path TEXT,
    command TEXT,
    timestamp INTEGER NOT NULL,
    details TEXT
);

CREATE TABLE FileEntity (
    id TEXT PRIMARY KEY NOT NULL,
    sessionId TEXT NOT NULL,
    name TEXT NOT NULL,
    mimeType TEXT NOT NULL,
    size INTEGER NOT NULL,
    storagePath TEXT NOT NULL,
    timestamp INTEGER NOT NULL,
    FOREIGN KEY (sessionId) REFERENCES ChatSessionEntity(id)
);

-- Queries
insertModel:
INSERT OR REPLACE INTO ModelEntity(id, name, provider, description)
VALUES (?, ?, ?, ?);

getAllModels:
SELECT * FROM ModelEntity;

insertSession:
INSERT OR REPLACE INTO ChatSessionEntity(id, title, createdAt, modelId, providerId)
VALUES (?, ?, ?, ?, ?);

getAllSessions:
SELECT * FROM ChatSessionEntity ORDER BY createdAt DESC;

getSessionById:
SELECT * FROM ChatSessionEntity WHERE id = ?;

updateSessionModel:
UPDATE ChatSessionEntity SET modelId = ? WHERE id = ?;

insertMessage:
INSERT INTO MessageEntity(id, sessionId, role, content, timestamp, attachments)
VALUES (?, ?, ?, ?, ?, ?);

getMessagesBySessionId:
SELECT * FROM MessageEntity WHERE sessionId = ? ORDER BY timestamp ASC;

deleteSession:
DELETE FROM ChatSessionEntity WHERE id = ?;

deleteMessagesBySessionId:
DELETE FROM MessageEntity WHERE sessionId = ?;

upsertAppState:
INSERT OR REPLACE INTO AppStateEntity(id, value)
VALUES (?, ?);

getAppState:
SELECT value FROM AppStateEntity WHERE id = ?;

deleteAppState:
DELETE FROM AppStateEntity WHERE id = ?;

insertAuditEvent:
INSERT INTO AuditEventEntity(id, kind, sessionId, approvalId, path, command, timestamp, details)
VALUES (?, ?, ?, ?, ?, ?, ?, ?);

getAuditEvents:
SELECT * FROM AuditEventEntity ORDER BY timestamp DESC;

insertFile:
INSERT INTO FileEntity(id, sessionId, name, mimeType, size, storagePath, timestamp)
VALUES (?, ?, ?, ?, ?, ?, ?);

getFilesBySessionId:
SELECT * FROM FileEntity WHERE sessionId = ? ORDER BY timestamp DESC;

getFileById:
SELECT * FROM FileEntity WHERE id = ?;

deleteFile:
DELETE FROM FileEntity WHERE id = ?;
